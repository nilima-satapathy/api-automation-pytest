{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UserList",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["id", "name", "username", "email"],
    "properties": {
      "id": { "type": "integer" },
      "name": { "type": "string" },
      "username": { "type": "string" },
      "email": { "type": "string" }
    }
  }
}
