{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PostList",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["userId", "id", "title", "body"],
    "properties": {
      "userId": { "type": "integer" },
      "id": { "type": "integer" },
      "title": { "type": "string" },
      "body": { "type": "string" }
    }
  }
}
